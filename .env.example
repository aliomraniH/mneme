# --- Required ---

# Replit Helium Postgres. Internal hostname `helium` only resolves from inside
# Replit; this URL will NOT work from a laptop. Use Replit Secrets for production
# and run any local exploration against a separate Postgres.
#
# IMPORTANT: do NOT commit the real password. Put the real value in Replit
# Secrets under DATABASE_URL. This file is the example only.
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# Upstream DB MCP server(s).
#
# Option A — single server (backward-compatible, assigned to the "default" namespace):
UPSTREAM_DB_MCP_URL=https://your-db-mcp.<your-replit-handle>.replit.app/mcp
#
# Option B — multiple servers (JSON mapping of namespace→URL).
# Use this when you want mneme to observe calls across several managed databases.
# UPSTREAM_DB_MCP_SERVERS={"saaz_demo": "https://saaz-yourhandle.replit.app/mcp", "pg_main": "https://pg-yourhandle.replit.app/mcp"}
#
# Only one of UPSTREAM_DB_MCP_URL or UPSTREAM_DB_MCP_SERVERS needs to be set.

# --- DB MCP upstream DSNs ---

# Connection string for the neon-purple-kite Vercel/Neon database.
# Backs the neon-mcp workflow (DB_MCP_TOOL_PREFIX=neon, port 3000).
DATABASE_URL_NEON_PURPLE_KITE=postgresql://user:pass@host/neondb?sslmode=require

# Connection string for the library-demo Vercel/Neon database (separate DB).
# Backs the library-demo workflow (DB_MCP_TOOL_PREFIX=lib, port 3001).
# Required — must be a distinct database from DATABASE_URL_NEON_PURPLE_KITE.
DATABASE_URL_LIBRARY_DEMO=postgresql://user:pass@host/neondb?sslmode=require

# --- Vercel integration (provision_database tool) ---

# Vercel API token with Storage write permissions.
# Create at: https://vercel.com/account/tokens
# Scope: Full Account (or a team token if VERCEL_TEAM_ID is set).
# Required to use the provision_database tool with provider="vercel".
VERCEL_API_TOKEN=

# Vercel team ID (slug or cuid). Required only for team-scoped accounts.
# Find it at: https://vercel.com/teams/<your-team>/settings
# Leave blank for personal accounts.
VERCEL_TEAM_ID=

# --- Anthropic (Phase 2+) ---

# Anthropic API key for the LangGraph agent (Phase 2+).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Embeddings (Phase 2.5 — warm_up / thread_refresh / log_context_summary) ---

# Anthropic has NO embeddings endpoint. For semantic ranking of project memory,
# set ONE of the following. If neither is set, mneme falls back to rule-based
# ranking (frequency + recency) — everything still works, just less precise.
#
# OpenAI: text-embedding-3-small is 1536-dim and matches the schema natively.
OPENAI_API_KEY=
# Voyage (Anthropic's recommended partner). Most Voyage models are NOT 1536-dim;
# set EMBEDDING_DIMENSIONS to match and reindex if you use this.
VOYAGE_API_KEY=
# Embedding dimension (must equal the vector() size; default 1536).
EMBEDDING_DIMENSIONS=1536

# --- Project-scoped extended memory (Phase 2.5) ---

# Fallback project label when a request carries no X-Mneme-Project header.
# Each Claude project should set that header in its .mcp.json so its memory
# stays isolated, e.g.:
#   "mneme": { "type": "http", "url": "https://.../mcp",
#              "headers": { "X-Mneme-Project": "marketing-q2" } }
MNEME_PROJECT_ID=default
# Token budget for the warm_up injected block (default 2000).
WARM_UP_MAX_TOKENS=2000
# Token budget for thread_refresh NEW additions only (default 1200).
THREAD_REFRESH_MAX_TOKENS=1200
# Cosine similarity above which a new memory is merged, not duplicated (0..1).
MEMORY_DEDUP_THRESHOLD=0.92

# --- Server ---

MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=5000
LOG_LEVEL=INFO

# --- Session management ---

# Seconds of inactivity before a session is marked idle_timeout (default 1800 = 30 min)
SESSION_IDLE_TIMEOUT_SECONDS=1800
# How often the idle reaper checks for stale sessions (default 60 s)
SESSION_IDLE_CHECK_INTERVAL_SECONDS=60
# Per-tool-call hard timeout in seconds (default 30)
PER_CALL_TIMEOUT_SECONDS=30
# Seconds to wait for in-flight calls to finish during shutdown (default 5)
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=5

# --- Rate limiting ---

# Max requests per minute per IP on /mcp (default 60)
RATE_LIMIT_PER_MINUTE=60

# --- Audit ---

# Max bytes stored in query_episode.result_summary (default 4096)
RESULT_SUMMARY_MAX_BYTES=4096

# Number of trusted reverse-proxy hops between the internet and mneme.
# 0 (default): use req.client.host — cannot be forged by the caller.
# 1: use XFF[-2] — the IP inserted by the immediately-upstream trusted proxy.
# Set to 1 if mneme sits behind exactly one reverse proxy (e.g. Replit's edge).
TRUSTED_PROXY_HOPS=0

# --- Optional ---

# LangSmith tracing. Highly recommended; free tier is enough for solo MVP.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mneme
LANGCHAIN_TRACING_V2=true

# Comma-separated list of allowed db_namespace values for the rule-based router.
# Add your database namespaces here when connecting additional managed services.
MNEME_NAMESPACES=pg_main,pinecone_main,saaz_demo,default

# Per-namespace routing keyword overrides (JSON mapping).
# When set, replaces the built-in keyword rules for ALL namespaces.
# Built-in defaults: saaz_demo→[artist,song,saaz,genre,...], pg_main→[postgres,sql,...],
# pinecone_main→[pinecone,embedding_index].
# Use this to add routing for new databases without touching source code.
# MNEME_NAMESPACE_ROUTING_KEYWORDS={"my_db": ["mytable", "myschema"], "pg_main": ["postgres", "sql"]}

# Embedding model for memory vectors. Must produce 1536-dim vectors
# (matches the column type in migrations/0001_init.sql).
MNEME_EMBEDDING_MODEL=text-embedding-3-small
