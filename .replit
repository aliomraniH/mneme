modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start neon-mcp"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn agent_service.server:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start neon-mcp"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn neon_mcp.server:app --host 0.0.0.0 --port 3000"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["uvicorn", "agent_service.server:app", "--host", "0.0.0.0", "--port", "5000"]

[userenv]

[userenv.shared]
UPSTREAM_DB_MCP_SERVERS = "{\"saaz_demo\":\"https://saaz-aloomrani.replit.app/mcp\",\"neon_purple_kite\":\"http://localhost:3000/mcp/\"}"
NAMESPACE_ROUTING_KEYWORDS = "{\"saaz_demo\":[\"artist\",\"song\",\"saaz\",\"genre\",\"persian\",\"jazz\",\"album\",\"saaz_\"],\"neon_purple_kite\":[\"neon_\",\"patient\",\"mrn\",\"medical\",\"clinical\",\"insurance\",\"neon_purple_kite\"],\"pg_main\":[\"postgres\",\"pg_main\"],\"pinecone_main\":[\"pinecone\",\"embedding\",\"vector\"]}"
